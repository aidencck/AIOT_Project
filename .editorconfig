root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,xml,yml,yaml,properties}]
indent_size = 4
indent_style = space

[*.{json,md,html,js,css,sh}]
indent_size = 2
indent_style = space

[Makefile]
indent_style = tab
